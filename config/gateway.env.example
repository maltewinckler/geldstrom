# Copy this file to gateway.env and fill in real values.
#
# Generate a secure password with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"

# ── Gateway app DB user ────────────────────────────────────────────────────────
GATEWAY_DB_USER=gateway
GATEWAY_DB_PASSWORD=change_me
# 'postgres' is the Docker service name. Override with GATEWAY_DB_HOST=localhost
# when running the gateway directly (outside Docker).
GATEWAY_DB_HOST=postgres
GATEWAY_DB_PORT=5432
GATEWAY_DB_NAME=geldstrom

# ── Server ────────────────────────────────────────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
# Must stay at 1 until Redis-backed state is added (see PRD § scalability)
GATEWAY_WORKERS=1
GATEWAY_LOG_LEVEL=INFO

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used for pending operation session storage.  Docker Compose overrides this
# with 'redis://redis:6379/0' via the environment: block.
GATEWAY_REDIS_URL=redis://localhost:6379/0
GATEWAY_JSON_LOGS=true

# ── Argon2id key hashing ───────────────────────────────────────────────────────
GATEWAY_ARGON2_TIME_COST=2
GATEWAY_ARGON2_MEMORY_COST=65536
GATEWAY_ARGON2_PARALLELISM=2

# ── Operation sessions ─────────────────────────────────────────────────────────
GATEWAY_OPERATION_SESSION_TTL_SECONDS=120
GATEWAY_OPERATION_SESSION_MAX_COUNT=10000

# ── Rate limiting ──────────────────────────────────────────────────────────────
GATEWAY_RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ── PostgreSQL NOTIFY reconnect ────────────────────────────────────────────────
GATEWAY_NOTIFY_RECONNECT_BACKOFF_SECONDS=1.0

# ── FinTS product ──────────────────────────────────────────────────────────────
GATEWAY_FINTS_PRODUCT_VERSION=1.0.0
