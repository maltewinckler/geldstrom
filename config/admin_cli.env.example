# Copy this file to admin_cli.env and fill in real values.
#
# Generate a secure password with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"

# ── PostgreSQL superuser ───────────────────────────────────────────────────────
# These are the canonical variable names consumed by the official postgres
# Docker image and by the admin CLI pydantic Settings.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=geldstrom
# 'postgres' is the Docker service name.  Override with POSTGRES_HOST=localhost
# when running gw-admin directly (outside Docker).
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── FinTS product registration ─────────────────────────────────────────────────
# Applied automatically during 'gw-admin db init'.
FINTS_PRODUCT_REGISTRATION_KEY=your_product_key_here
FINTS_PRODUCT_VERSION=1.0.0

# ── Gateway app user — created by 'gw-admin db init' ─────────────────────────
# This is the restricted user the gateway service connects as.
GATEWAY_DB_USER=gateway
GATEWAY_DB_PASSWORD=change_me

# ── Argon2id key hashing ───────────────────────────────────────────────────────
ADMIN_ARGON2_TIME_COST=2
ADMIN_ARGON2_MEMORY_COST=65536
ADMIN_ARGON2_PARALLELISM=2

# ── SMTP (admin UI — token delivery) ──────────────────────────────────────────
# Tokens are never stored; they are emailed to users on creation and reroll.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=admin@example.com
SMTP_PASSWORD=change_me
SMTP_FROM_EMAIL=noreply@example.com
# Set to false for plain SMTP (port 25) or STARTTLS on port 587
SMTP_USE_TLS=true

# ── Admin UI server ────────────────────────────────────────────────────────────
# Port the FastAPI admin UI listens on inside the container.
# Access via SSH port-forwarding: ssh -L 8001:localhost:8001 user@vps
ADMIN_UI_PORT=8000
