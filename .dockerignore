# Version control
.git/
.gitignore

# Python runtime artifacts
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# Virtual environment (rebuilt in the image)
.venv/

# Build / test caches
.pytest_cache/
.ruff_cache/

# Development tooling
.vscode/

# Test suite
tests/

# Documentation and examples
docs/
examples/

# Local data files
data/

# Secrets — never bake .env files into the image; all config is passed via
# environment variables at runtime (see docker-compose.yml).
config/

# Dev-only workspace package source (pyproject.toml is still needed for dep
# resolution via bind mount in the Dockerfile, but the source is not COPYed).
packages/geldstrom_cli/geldstrom_cli/
